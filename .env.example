# ChemistryTimes — Environment Variables
# Copy to .env: cp .env.example .env

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
DB_NAME=chemistrytimes

# Server port
PORT=17171

# API key for mutation endpoints (POST/PATCH/DELETE)
# Generate one with: openssl rand -hex 32
API_KEY=dev-api-key-change-me
